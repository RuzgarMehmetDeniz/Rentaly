@model List<LatestNew>
@{
    Layout = null;
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}
<!DOCTYPE html>
<html lang="zxx">

@await Component.InvokeAsync("_DefaultHeadComponentPartial")

<body>
    <div id="wrapper">
        <div id="de-preloader"></div>

        @await Component.InvokeAsync("_DefaultNavbarComponentPartial")

        <div class="no-bottom no-top" id="content">
            <div id="top"></div>

            <section id="subheader" class="jarallax text-light">
                <img src="/rentaly/images/background/subheader.jpg" class="jarallax-img" alt="">
                <div class="center-y relative text-center">
                    <div class="container">
                        <div class="row">
                            <div class="col-md-12 text-center">
                                <h1>Haber Sayfası</h1>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section id="section-content" aria-label="section">
                <div class="container">
                    <div class="row gx-5">

                        <div class="col-lg-10 offset-lg-1">
                            @foreach (var item in Model)
                            {
                                <div class="de-post-type-1">
                                    <div class="d-image">
                                        <img alt="" src="@item.ImageUrl" class="lazy">
                                    </div>
                                    <div class="d-content">
                                        <div class="d-meta">
                                            <span class="d-by">@item.Author</span>
                                            <span class="d-date"> @item.CreatedDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</span>
                                        </div>
                                        <h4><a href="/News/Details/@item.LatestNewId">@item.Title<span></span></a></h4>
                                        <p>@item.Description</p>
                                        <a href="/News/Details/@item.LatestNewId" class="btn-main">Devamını Oku</a>
                                    </div>
                                </div>
                            }
                        </div>

                    </div>

                    <div class="row">
                        <div class="col-md-12 text-center">
                            <ul class="pagination">
                                @if (currentPage > 1)
                                {
                                    <li><a href="/News/Index?page=@(currentPage - 1)">Geri</a></li>
                                }

                                @for (int i = 1; i <= totalPages; i++)
                                {
                                    <li class="@(i == currentPage ? "active" : "")">
                                        <a href="/News/Index?page=@i">@i</a>
                                    </li>
                                }

                                @if (currentPage < totalPages)
                                {
                                    <li><a href="/News/Index?page=@(currentPage + 1)">İleri</a></li>
                                }
                            </ul>
                        </div>
                    </div>

                </div>
            </section>
        </div>
    </div>

    <a href="#" id="back-to-top"></a>
    @await Component.InvokeAsync("_DefaultFooterComponentPartial")
    @await Component.InvokeAsync("_DefaultScriptComponentPartial")

</body>
</html>

<style>
    /* PAGINATION STİLLERİ */
    .pagination {
        display: inline-flex;
        padding-left: 0;
        list-style: none;
        margin-top: 30px;
    }

        .pagination li {
            margin: 0 5px;
        }

            .pagination li a {
                padding: 8px 16px;
                border: 1px solid #dee2e6;
                color: #111;
                text-decoration: none;
                border-radius: 4px;
                font-weight: bold;
                transition: 0.3s all;
            }

            .pagination li.active a {
                background-color: #1ecb15; /* Temanın yeşil tonu */
                border-color: #1ecb15;
                color: white;
            }

            .pagination li a:hover:not(.active) {
                background-color: #f8f9fa;
                border-color: #1ecb15;
                color: #1ecb15;
            }

    /* SENİN MEVCUT GENEL STİLLERİN */
    html, body {
        margin: 0 !important;
        padding: 0 !important;
        overflow-x: hidden;
    }

    header {
        top: 0 !important;
        margin: 0 !important;
    }

    #content {
        padding: 0 !important;
        margin: 0 !important;
    }

    section {
        padding: 80px 0 !important;
        margin: 0 !important;
        border: none !important;
    }

    footer {
        margin-top: 0 !important;
        padding-top: 60px !important;
    }

    .subfooter {
        padding: 15px 0 !important;
        background: #111 !important;
    }

    /* Spacerları pagination düzgün görünsün diye bu sayfada açabilirsin
           veya pagination'ı ayrı bir satıra aldığım için kapalı tutabilirsin. */
    .spacer-single {
        display: none !important;
    }

    #wrapper {
        width: 100%;
        overflow: hidden;
    }
</style>