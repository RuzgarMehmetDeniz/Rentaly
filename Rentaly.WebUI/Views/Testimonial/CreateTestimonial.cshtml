@model Testimonial

@{
    ViewData["Title"] = "Yeni Müşteri Yorumu";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom py-3">
                    <div class="d-flex align-items-center">
                        <div class="icon-shape bg-success bg-opacity-10 text-success rounded-3 me-3 p-2">
                            <i class="fa-solid fa-plus fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">Yeni Yorum Ekle</h5>
                            <small class="text-muted">Sistemde görünecek yeni bir müşteri geri bildirimi oluşturun.</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="CreateTestimonial" method="post">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark">Adı</label>
                                <input type="text" asp-for="Name" class="form-control bg-light" placeholder="Örn: Ahmet" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-dark">Soyadı</label>
                                <input type="text" asp-for="Surname" class="form-control bg-light" placeholder="Örn: Yılmaz" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold text-dark">Ünvan / Başlık</label>
                                <input type="text" asp-for="Title" class="form-control bg-light" placeholder="Örn: Yazılım Mühendisi veya Müşteri" required>
                            </div>
                            <div class="col-md-9">
                                <label class="form-label fw-semibold text-dark">Profil Fotoğrafı URL</label>
                                <input type="text" asp-for="ImageUrl" id="imageUrlInput" class="form-control bg-light" placeholder="https://..." required>
                            </div>
                            <div class="col-md-3 text-center">
                                <label class="form-label fw-semibold text-dark">Önizleme</label>
                                <div class="rounded-circle border mx-auto overflow-hidden shadow-sm" style="width: 70px; height: 70px; background: #f8f9fa;">
                                    <img src="" id="imgPreview" class="w-100 h-100" style="object-fit: cover;" onerror="this.src='/images/no-user.png'">
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold text-dark">Müşteri Yorumu</label>
                                <textarea asp-for="Comment" class="form-control bg-light" rows="5" placeholder="Müşterinin mesajını buraya yazın..." required></textarea>
                            </div>
                            <div class="col-12 mt-4 text-end">
                                <hr class="opacity-5 mb-4">
                                <a href="/Testimonial/Index" class="btn btn-light px-4 rounded-3 border me-2">Vazgeç</a>
                                <button type="submit" class="btn btn-warning px-5 rounded-3 text-white fw-bold shadow-sm">Kaydet</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('imageUrlInput').addEventListener('input', function() {
        document.getElementById('imgPreview').src = this.value;
    });
</script>