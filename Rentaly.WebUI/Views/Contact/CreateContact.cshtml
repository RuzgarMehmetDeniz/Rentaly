@model Rentaly.EntityLayer.Entities.Contact

@{
    ViewData["Title"] = "Yeni İletişim Ekle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white">
            <h5 class="m-0 font-weight-bold text-success">
                <i class="fas fa-plus-circle me-2"></i>Yeni İletişim Bilgisi Ekle
            </h5>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold">Adres</label>
                    <input type="text" asp-for="Address" class="form-control" placeholder="Adresi giriniz..." />
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Telefon</label>
                        <input type="text" asp-for="Phone" class="form-control" placeholder="Telefon numarasını giriniz..." />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">E-posta</label>
                        <input type="email" asp-for="Email" class="form-control" placeholder="E-posta adresini giriniz..." />
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="fas fa-save me-1"></i> Kaydet
                    </button>
                    <a href="/Contact/Index/" class="btn btn-outline-secondary px-4 ms-2">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>