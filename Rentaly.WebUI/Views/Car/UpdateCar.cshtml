@model Rentaly.EntityLayer.Entities.Car
@{
    ViewData["Title"] = "Araç Güncelle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    /* Liste sayfasındaki aynı değişkenleri ve fontları kullanıyoruz */
    .update-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    .update-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--border);
        background: #fafbfc;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .update-body {
        padding: 24px;
    }

    .form-label-custom {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 700;
        font-size: 13px;
        color: var(--text-main);
        margin-bottom: 7px;
        display: block;
    }

    .form-control-custom {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 14px;
        transition: var(--transition);
        background: var(--body-bg);
    }

        .form-control-custom:focus {
            border-color: var(--primary);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,86,219,0.1);
            outline: none;
        }

    .img-preview-box {
        width: 100%;
        height: 200px;
        border-radius: var(--radius);
        border: 2px dashed var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background: #f8fafc;
        margin-top: 28px;
    }

        .img-preview-box img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    .toggle-switch {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">Araç Düzenle</h1>
        <p class="page-subtitle">ID: #@Model.CarId — @Model.PlateNumber</p>
    </div>
    <a href="/Car/CarList" class="btn-action btn-detail" style="text-decoration:none;">
        <i class="fa-solid fa-arrow-left"></i> Listeye Dön
    </a>
</div>

<form asp-action="UpdateCar" method="post">
    <input type="hidden" asp-for="CarId" />

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="update-card">
                <div class="update-header">
                    <h6 class="mb-0" style="font-weight:800; font-family:'Plus Jakarta Sans';"><i class="fa-solid fa-info-circle me-2 text-primary"></i>Genel Bilgiler</h6>
                </div>
                <div class="update-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label-custom">Marka</label>
                            <select asp-for="BrandId" asp-items="ViewBag.Brands" class="form-control-custom"></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-custom">Model</label>
                            <select asp-for="ModelId" asp-items="ViewBag.Models" class="form-control-custom"></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-custom">Kategori</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control-custom"></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-custom">Şube</label>
                            <select asp-for="BranchId" asp-items="ViewBag.Branches" class="form-control-custom"></select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Plaka</label>
                            <input asp-for="PlateNumber" class="form-control-custom" style="text-transform: uppercase;" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Yıl</label>
                            <input asp-for="Year" type="number" class="form-control-custom" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Kilometre</label>
                            <input asp-for="Kilometer" type="number" class="form-control-custom" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="update-card mt-4">
                <div class="update-header">
                    <h6 class="mb-0" style="font-weight:800; font-family:'Plus Jakarta Sans';"><i class="fa-solid fa-gears me-2 text-primary"></i>Teknik & Fiyat Bilgileri</h6>
                </div>
                <div class="update-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label-custom">Günlük Fiyat (₺)</label>
                            <input asp-for="DailyPrice" class="form-control-custom" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Depozito (₺)</label>
                            <input asp-for="DepositAmount" class="form-control-custom" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Yakıt Tipi</label>
                            <select asp-for="FuelType" class="form-control-custom">
                                <option value="Benzin">Benzin</option>
                                <option value="Dizel">Dizel</option>
                                <option value="Elektrik">Elektrik</option>
                                <option value="Hibrit">Hibrit</option>
                                <option value="LPG">LPG</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Koltuk Sayısı</label>
                            <input asp-for="SeatCount" class="form-control-custom" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Bavul Kapasitesi</label>
                            <input asp-for="LuggageCount" class="form-control-custom" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Şasi No (VIN)</label>
                            <input asp-for="VIN" class="form-control-custom" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="update-card">
                <div class="update-header">
                    <h6 class="mb-0" style="font-weight:800; font-family:'Plus Jakarta Sans';"><i class="fa-solid fa-sliders me-2 text-primary"></i>Yönetim</h6>
                </div>
                <div class="update-body">
                    <div class="mb-4">
                        <div class="form-check form-switch custom-switch">
                            <input class="form-check-input" type="checkbox" asp-for="IsAvailable">
                            <label class="form-check-label fw-bold ms-2" asp-for="IsAvailable">Kiralama İçin Müsait</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label-custom">Görsel URL</label>
                        <input asp-for="ImageUrl" class="form-control-custom" id="imageUrlInput" placeholder="https://..." />
                    </div>

                    <div class="img-preview-box">
                        <img src="@Model.ImageUrl" id="imgPreview" onerror="this.src='/images/no-car.png'" />
                    </div>
                </div>
                <div class="update-footer" style="padding:20px; background:#f8fafc; border-top:1px solid var(--border);">
                    <button type="submit" class="btn-primary-custom w-100" style="padding:12px;">
                        <i class="fa-solid fa-save me-2"></i> Değişiklikleri Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        // Görsel URL değiştiğinde anlık önizleme yap
        document.getElementById('imageUrlInput').addEventListener('input', function() {
            document.getElementById('imgPreview').src = this.value;
        });
    </script>
}