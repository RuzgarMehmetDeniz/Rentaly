@model List<FAQ>

@{
    ViewData["Title"] = "Sıkça Sorulan Sorular";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Sıkça Sorulan Sorular</h3>
            <p class="text-muted small">Soru ve cevap yönetimi paneli.</p>
        </div>
        <a href="/FAQ/CreateFAQ" class="btn btn-warning text-white fw-bold px-4 rounded-3">
            <i class="fa-solid fa-plus me-2"></i> Yeni Soru Ekle
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3" style="width: 80px;">#</th>
                            <th class="py-3">Soru</th>
                            <th class="py-3">Cevap</th>
                            <th class="py-3 text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 font-weight-bold text-muted">#@item.FAQId</td>
                                <td><h6 class="mb-0 text-sm fw-bold">@item.Title</h6></td>
                                <td><p class="text-xs text-muted mb-0">@item.Description</p></td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="/FAQ/UpdateFAQ/@item.FAQId" class="btn btn-sm btn-outline-primary rounded-3">
                                            <i class="fa-solid fa-pen-to-square"></i> Düzenle
                                        </a>

                                        @* HİÇBİR JS YOK: Tıklandığı anda siler *@
                                        <a href="/FAQ/DeleteFAQ/@item.FAQId" class="btn btn-sm btn-outline-danger rounded-3">
                                            <i class="fa-solid fa-trash"></i> Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-size: 0.75rem;
        background-color: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
    }

    .table tbody td {
        padding: 1rem 0.5rem;
        border-bottom: 1px solid #f1f1f1;
    }
</style>