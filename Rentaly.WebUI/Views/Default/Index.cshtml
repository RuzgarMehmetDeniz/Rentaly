@{
	Layout = null;
}

<!DOCTYPE html>

<html lang="zxx">

	@await Component.InvokeAsync("_DefaultHeadComponentPartial")

<body onload="initialize()">

	<div id="wrapper">

		@await Component.InvokeAsync("_DefaultNavbarComponentPartial")
		<br /><br />

		<div class="no-bottom no-top" id="content">

			<div id="top"></div>

			@await Component.InvokeAsync("_DefaultHeroComponentPartial")

			@await Component.InvokeAsync("_DefaultBrandComponentPartial")

			@await Component.InvokeAsync("_DefaultOurFeatureComponentPartial")

			@await Component.InvokeAsync("_DefaultStatisticComponentPartial")
			
			@await Component.InvokeAsync("_DefaultCarComponentPartial")	

			@await Component.InvokeAsync("_DefaultAwardsComponentPartial")

			@await Component.InvokeAsync("_DefaultBlogComponentPartial")	

			@await Component.InvokeAsync("_DefaultTestimonialComponentPartial")	

			@await Component.InvokeAsync("_DefaultFAQComponentPartial")	

			@await Component.InvokeAsync("_DefaultCallUsNowComponentPartial")

		</div>

		@await Component.InvokeAsync("_DefaultFooterComponentPartial")

		@await Component.InvokeAsync("_DefaultScriptComponentPartial")

	</div>

</body>

</html>
<style>
	/* 1. Ana Footer'ın alt boşluğunu daralt */
	footer {
		padding-top: 40px !important; /* Üstten biraz boşluk kalsın */
		padding-bottom: 0px !important; /* Alttaki büyük boşluğu sıfırla */
	}

		/* 2. "Copyright" yazan en alt bandı daralt */
		footer .subfooter {
			padding: 10px 0 !important; /* Standart 30-40px olan boşluğu 10px'e çeker */
			margin: 0 !important;
		}

		/* 3. Footer içindeki son elemanın (genelde row veya container)
	   fazladan bıraktığı margin'i temizle */
		footer .container {
			margin-bottom: 0 !important;
			padding-bottom: 0 !important;
		}

	/* 4. Sayfanın en altındaki siyah boşluğu tamamen yok etmek için */
	#wrapper {
		overflow: hidden;
	}
	footer {
		padding-top: 40px !important; /* Üst boşluğu biraz daralttık */
		padding-bottom: 20px !important; /* Alt boşluğu ciddi oranda azalttık */
	}

		/* Telif hakkı (Copyright) kısmının altındaki ekstra boşluğu siler */
		footer .subfooter {
			padding: 20px 0 !important;
			margin: 0 !important;
		}
	/* Ana içerik kapsayıcısının altındaki 90px'lik zorunlu boşluğu kaldırır */
	#content.no-bottom.no-top {
		padding-bottom: 0 !important;
	}

	/* Footer'ın üstünde oluşabilecek otomatik margin'i sıfırlar */
	footer {
		margin-top: 0 !important;
	}
	/* Tüm sectionlar arası boşluğu zorla kapatır */
	section, header, footer {
		margin: 0 !important;
		padding-top: 60px !important; /* Standart padding */
		padding-bottom: 60px !important;
	}

	/* Yeşil alanın (Call to Action) altındaki boşluğu öldürür */
	.v-center, .v-align-children {
		padding-bottom: 0 !important;
		margin-bottom: 0 !important;
	}

	/* Eğer arada boş bir div varsa onu gizler */
	.spacer-single, .spacer-double, .spacer-60 {
		display: none !important;
	}
	/* 1. Sayfanın en tepesindeki hayalet boşluğu siler */
	html, body {
		margin: 0 !important;
		padding: 0 !important;
	}

	/* 2. Navbar'ın (Header) üzerindeki boşluğu sıfırlar */
	header {
		top: 0 !important;
		margin-top: 0 !important;
		padding-top: 0 !important;
		position: absolute; /* Veya fixed, temanın yapısına göre */
		width: 100%;
		z-index: 1001;
	}

	/* 3. Navbar'ın hemen altındaki ilk bölümün (genelde slider veya subheader)
	   Navbar'ın altında kalmaması için gereken ayar */
	#content {
		padding-top: 0 !important;
		margin-top: 0 !important;
	}

	/* 4. Senin o yeşil alan ile siyah alan arasındaki boşluk için nokta atışı: */
	section#call-to-action,
	.section-dark,
	footer {
		margin-top: 0 !important;
		margin-bottom: 0 !important;
		border: none !important;
	}
</style>