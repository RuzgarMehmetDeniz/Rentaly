@model List<Rentaly.EntityLayer.Entities.Rental>

@{
    ViewData["Title"] = "Rezervasyon Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";

    int count = 0;
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-calendar-check me-2"></i> Rezervasyon Yönetimi
            </h5>
            <a href="/AdminBooking/CreateBooking/" class="btn btn-primary btn-sm rounded-pill px-4">
                <i class="fas fa-plus me-1"></i> Yeni Rezervasyon
            </a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="text-secondary opacity-7">#</th>
                            <th class="text-secondary opacity-7">Müşteri</th>
                            <th class="text-secondary opacity-7">İletişim</th>
                            <th class="text-secondary opacity-7">Alış Tarihi</th>
                            <th class="text-secondary opacity-7">Dönüş Tarihi</th>
                            <th class="text-secondary opacity-7">Tutar</th>
                            <th class="text-secondary opacity-7">Durum</th>
                            <th class="text-center text-secondary opacity-7">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td><span class="fw-bold">@count</span></td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="text-dark fw-semibold">@item.NameSurname</span>
                                        <small class="text-muted">ID: #@item.RentalId</small>
                                    </div>
                                </td>
                                <td>
                                    <div class="small">
                                        <i class="fas fa-envelope text-muted me-1"></i> @item.Email<br />
                                        <i class="fas fa-phone text-muted me-1"></i> @item.Phone
                                    </div>
                                </td>
                                <td>@item.PickupDate.ToString("dd MMM yyyy")</td>
                                <td>@item.ReturnDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge bg-soft-success text-success fw-bold">
                                        @item.TotalPrice.ToString("C2")
                                    </span>
                                </td>
                                <td>
                                    @if (item.Status == "Onaylandı")
                                    {
                                        <span class="badge bg-success rounded-pill">Onaylandı</span>
                                    }
                                    else if (item.Status == "Beklemede")
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill">Beklemede</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill">@item.Status</span>
                                    }
                                </td>
                                <a href="/AdminBooking/SendConfirmation/@item.RentalId" class="btn btn-outline-info">
                                    <i class="fa fa-paper-plane"></i> Onay Maili Gönder
                                </a>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm">
                                        <a href="/AdminBooking/UpdateBooking/@item.RentalId" class="btn btn-outline-warning btn-sm border-0" title="Güncelle">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="/AdminBooking/DeleteBooking/@item.RentalId" class="btn btn-outline-danger btn-sm border-0" title="Sil">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Modern Tasarım Dokunuşları */
    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom-width: 1px;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.03);
        transition: background-color 0.3s ease;
    }

    .bg-soft-success {
        background-color: #e8fadf;
        color: #28a745;
        padding: 5px 10px;
        border-radius: 8px;
    }

    .btn-group .btn {
        margin: 0 2px;
        border-radius: 6px !important;
    }

    .card {
        border-radius: 12px;
    }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />