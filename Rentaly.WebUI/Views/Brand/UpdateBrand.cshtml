@model Rentaly.EntityLayer.Entities.Brand
@{
    ViewData["Title"] = "Marka Güncelle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    .update-brand-container {
        max-width: 800px;
        margin: 2rem auto;
    }

    .card-modern {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .card-modern-header {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        color: white;
        padding: 1.5rem;
    }

    .card-modern-body {
        padding: 2.5rem;
    }

    .form-control-modern {
        border-radius: 8px;
        padding: 0.75rem 1rem;
        border: 1px solid #ced4da;
    }

    .preview-container {
        border: 2px dashed #dee2e6;
        border-radius: 12px;
        padding: 1rem;
        text-align: center;
        min-height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f8fafc;
    }

    #imagePreview {
        max-width: 100%;
        max-height: 180px;
        object-fit: contain;
        border-radius: 8px;
    }
</style>

<div class="container update-brand-container">
    <div class="card card-modern">
        <div class="card-modern-header">
            <h1 class="h4 mb-0"><i class="fa fa-edit me-2"></i>Marka Bilgilerini Güncelle</h1>
        </div>
        <div class="card-modern-body">
            <form asp-action="UpdateBrand" method="post">
                <input type="hidden" asp-for="BrandId" />

                <div class="row">
                    <div class="col-md-7">
                        <div class="mb-4">
                            <label class="form-label fw-bold">Marka Adı</label>
                            <input asp-for="BrandName" class="form-control form-control-modern" />
                            <span asp-validation-for="BrandName" class="text-danger"></span>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Logo URL</label>
                            <input asp-for="ImageUrl" id="imageUrlInput" class="form-control form-control-modern" />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="mb-2 fw-bold text-muted text-center">Mevcut / Yeni Logo</div>
                        <div class="preview-container">
                            <img id="imagePreview" src="@Model.ImageUrl" onerror="this.src='https://placehold.co/200x200?text=Hatalı+URL'" />
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a href="/Brand/Index" class="btn btn-light px-4">Vazgeç</a>
                    <button type="submit" class="btn btn-warning px-5 fw-bold text-white">Değişiklikleri Uygula</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const input = document.getElementById('imageUrlInput');
        const preview = document.getElementById('imagePreview');
        input.addEventListener('input', () => { preview.src = input.value; });
    </script>
}