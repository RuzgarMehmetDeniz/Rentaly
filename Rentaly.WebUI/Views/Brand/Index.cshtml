@model List<Brand>
@{
    ViewData["Title"] = "Marka Yönetimi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    :root {
        --primary: #4361ee;
        --bg-light: #f8fafc;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --card-bg: #ffffff;
        --border-color: #e2e8f0;
        --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    body {
        background-color: var(--bg-light);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
    }

    /* HEADER SECTİON */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
    }

    .page-title {
        font-weight: 800;
        font-size: 1.75rem;
        color: var(--text-main);
        margin: 0;
    }

    .page-subtitle {
        color: var(--text-muted);
        margin: 0;
    }

    /* STATS CARD */
    .stat-card {
        background: var(--card-bg);
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid var(--border-color);
        box-shadow: var(--shadow);
        margin-bottom: 2rem;
        display: inline-block;
        min-width: 200px;
    }

    .stat-val {
        font-size: 2rem;
        font-weight: 800;
        color: var(--primary);
        display: block;
    }

    .stat-label {
        font-size: 0.875rem;
        color: var(--text-muted);
        font-weight: 600;
        text-transform: uppercase;
    }

    /* TOOLBAR (Search) */
    .toolbar-container {
        margin-bottom: 2rem;
        background: var(--card-bg);
        padding: 1rem;
        border-radius: 10px;
        border: 1px solid var(--border-color);
    }

    .search-input {
        width: 100%;
        max-width: 400px;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        background: #f1f5f9;
        transition: all 0.3s;
    }

        .search-input:focus {
            outline: none;
            background: #fff;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.15);
        }

    /* BRAND GRID */
    .brand-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .brand-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

        .brand-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            border-color: var(--primary);
        }

    .brand-img-container {
        height: 160px;
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .brand-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }

    .brand-body {
        padding: 1.25rem;
        text-align: center;
    }

    .brand-name {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
        color: var(--text-main);
    }

    .brand-id-badge {
        font-size: 0.75rem;
        background: #f1f5f9;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        color: var(--text-muted);
        font-weight: 600;
    }

    .brand-footer {
        padding: 1rem;
        background: #fafafa;
        border-top: 1px solid var(--border-color);
        display: flex;
        gap: 8px;
    }

    .btn-action {
        flex: 1;
        padding: 0.5rem;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        text-align: center;
        text-decoration: none;
        transition: 0.2s;
        border: none;
    }

    .btn-detay {
        background: #e0f2fe;
        color: #0369a1;
    }

    .btn-duzenle {
        background: #fef3c7;
        color: #92400e;
    }

    .btn-sil {
        background: #fee2e2;
        color: #dc2626;
    }

    .btn-action:hover {
        opacity: 0.8;
        transform: scale(1.02);
        color: inherit;
    }

    /* EMPTY STATE */
    #no-results {
        display: none;
        text-align: center;
        padding: 3rem;
        color: var(--text-muted);
    }
</style>

<div class="page-header mt-4">
    <div>
        <h1 class="page-title">Marka Listesi</h1>
        <p class="page-subtitle">Sistemdeki tüm markaları buradan yönetebilirsiniz.</p>
    </div>
    <a href="/Brand/CreateBrand" class="btn btn-primary px-4 py-2" style="border-radius: 8px; font-weight: 600;">
        <i class="fa fa-plus me-2"></i> Yeni Marka Ekle
    </a>
</div>

<div class="stat-card">
    <span class="stat-label">Toplam Kayıtlı Marka</span>
    <span class="stat-val">@Model.Count()</span>
</div>

<div class="toolbar-container">
    <div class="row align-items-center">
        <div class="col-md-6">
            <input type="text" id="searchBrand" class="search-input" placeholder="Marka adıyla hızlı ara..." oninput="filterBrand()" />
        </div>
    </div>
</div>

<div class="brand-grid" id="brandGrid">
    @foreach (var item in Model)
    {
        <div class="brand-card" data-name="@item.BrandName.ToLower()">
            <div class="brand-img-container">
                <img src="@item.ImageUrl" class="brand-img" onerror="this.src='https://placehold.co/200x200?text=Logo+Yok'" />
            </div>

            <div class="brand-body">
                <div class="brand-name">@item.BrandName</div>
                <span class="brand-id-badge">ID: #@item.BrandId</span>
            </div>

            <div class="brand-footer">
                @* Detay artık bir modal açıyor *@
                <button type="button"
                        onclick="showBrandDetail('@item.BrandName', '@item.ImageUrl', '@item.BrandId')"
                        class="btn-action btn-detay">
                    Detay
                </button>

                <a href="/Brand/UpdateBrand/@item.BrandId" class="btn-action btn-duzenle">Düzenle</a>

                <button onclick="deleteBrand(@item.BrandId)" class="btn-action btn-sil">Sil</button>
            </div>
        </div>
    }
</div>
<div class="modal fade" id="brandDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 15px; border: none; overflow: hidden;">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">Marka Detay Bilgisi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-5">
                <div class="mb-4 p-3 border rounded-3 bg-light">
                    <img id="modalBrandImg" src="" style="max-height: 120px; max-width: 100%; object-fit: contain;" />
                </div>
                <h3 id="modalBrandName" class="fw-bold mb-1"></h3>
                <p id="modalBrandId" class="text-muted mb-4"></p>

                <div class="d-grid">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="no-results">
    <i class="fa fa-search fa-3x mb-3"></i>
    <p>Aradığınız kriterlere uygun marka bulunamadı.</p>
</div>

<script>
        function showBrandDetail(name, img, id) {
        // Modal içindeki elementlere verileri basıyoruz
        document.getElementById("modalBrandName").innerText = name;
        document.getElementById("modalBrandImg").src = img;
        document.getElementById("modalBrandId").innerText = "Sistem Kayıt ID: #" + id;

        // Bootstrap Modal'ı tetikliyoruz
        var detailModal = new bootstrap.Modal(document.getElementById('brandDetailModal'));
        detailModal.show();
    }
    function filterBrand() {
        let q = document.getElementById("searchBrand").value.toLowerCase();
        let cards = document.querySelectorAll(".brand-card");
        let visibleCount = 0;

        cards.forEach(c => {
            let name = c.dataset.name;
            if (name.includes(q)) {
                c.style.display = "";
                visibleCount++;
            } else {
                c.style.display = "none";
            }
        });

        // Arama sonucu yoksa mesajı göster
        document.getElementById("no-results").style.display = visibleCount === 0 ? "block" : "none";
    }

    function deleteBrand(id) {
        if (confirm("Bu markayı silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.")) {
            window.location = "/Brand/DeleteBrand/" + id;
        }
    }
</script>