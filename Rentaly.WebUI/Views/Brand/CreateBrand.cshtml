@model Rentaly.EntityLayer.Entities.Brand
@{
    ViewData["Title"] = "Yeni Marka Ekle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    /* Modern Kart ve Tasarım */
    .create-brand-container {
        max-width: 800px;
        margin: 2rem auto;
    }

    .card-modern {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .card-modern-header {
        background: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%);
        color: white;
        padding: 1.5rem;
        border: none;
    }

    .card-modern-title {
        font-weight: 800;
        margin: 0;
        font-size: 1.5rem;
    }

    .card-modern-body {
        padding: 2.5rem;
    }

    /* Form Elemanları */
    .form-label {
        font-weight: 600;
        color: #495057;
        margin-bottom: 0.5rem;
    }

    .form-control-modern {
        border-radius: 8px;
        padding: 0.75rem 1rem;
        border: 1px solid #ced4da;
        transition: all 0.2s;
    }

        .form-control-modern:focus {
            border-color: #4361ee;
            box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.15);
        }

    /* Resim Ön İzleme Bölümü */
    .preview-container {
        border: 2px dashed #dee2e6;
        border-radius: 12px;
        padding: 1rem;
        text-align: center;
        min-height: 200px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background-color: #f8fafc;
        transition: all 0.3s;
    }

        .preview-container.has-image {
            border-style: solid;
            border-color: #e2e8f0;
            background-color: white;
        }

    #imagePreview {
        max-width: 100%;
        max-height: 180px;
        object-fit: contain;
        display: none; /* Başlangıçta gizli */
        border-radius: 8px;
    }

    #previewPlaceholder {
        color: #adb5bd;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* Validation Hataları */
    .text-danger {
        font-size: 0.85rem;
        margin-top: 0.25rem;
    }
</style>

<div class="container create-brand-container">
    <a href="/Brand/Index" class="btn btn-sm btn-outline-secondary mb-3">
        <i class="fa fa-arrow-left me-1"></i> Listeye Dön
    </a>

    <div class="card card-modern">
        <div class="card-modern-header">
            <h1 class="card-modern-title">
                <i class="fa fa-plus-circle me-2"></i>Yeni Marka Oluştur
            </h1>
            <p class="mb-0 text-white-50">Sisteme yeni bir araç markası tanımlayın.</p>
        </div>

        <div class="card-modern-body">
            <form asp-action="CreateBrand" method="post" id="createBrandForm">
                @* Sunucu tarafı hata özetini göster (isteğe bağlı) *@
                @* <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div> *@

                <div class="row">
                    <div class="col-md-7">
                        <div class="mb-4">
                            <label asp-for="BrandName" class="form-label"></label>
                            <input asp-for="BrandName" class="form-control form-control-modern" placeholder="Örn: BMW, Mercedes, Toyota..." />
                            <span asp-validation-for="BrandName" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ImageUrl" class="form-label"></label>
                            <input asp-for="ImageUrl" id="imageUrlInput" class="form-control form-control-modern" placeholder="https://example.com/logo.png" />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                            <small class="text-muted d-block mt-1">Lütfen marka logosunun doğrudan URL'sini yapıştırın.</small>
                        </div>
                    </div>

                    <div class="col-md-5">
                        <div class="mb-2 fw-bold text-muted">Logo Ön İzleme</div>
                        <div class="preview-container" id="previewContainer">
                            <div id="previewPlaceholder">
                                <i class="fa fa-image fa-3x mb-2"></i>
                                <span>URL Girdiğinizde<br />Burada Görünecek</span>
                            </div>
                            <img id="imagePreview" src="#" alt="Marka Logosunun Ön İzlemesi" />
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2">
                    <button type="reset" class="btn btn-light px-4">Temizle</button>
                    <button type="submit" class="btn btn-primary px-5 fw-bold" style="border-radius: 8px;">
                        <i class="fa fa-save me-2"></i>Markayı Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @* ASP.NET Core İstemci Tarafı Validation (Boş geçilmemesi için) *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // --- Resim Ön İzleme Mantığı ---
        const imageUrlInput = document.getElementById('imageUrlInput');
        const imagePreview = document.getElementById('imagePreview');
        const previewPlaceholder = document.getElementById('previewPlaceholder');
        const previewContainer = document.getElementById('previewContainer');

        function updateImagePreview() {
            const url = imageUrlInput.value.trim();

            if (url) {
                // Giriş var, resmi yüklemeyi dene
                imagePreview.src = url;
                imagePreview.style.display = 'block'; // Resmi göster
                previewPlaceholder.style.display = 'none'; // Placeholder'ı gizle
                previewContainer.classList.add('has-image'); // Konteynırı güncelle
            } else {
                // Giriş boş, varsayılan duruma dön
                imagePreview.style.display = 'none';
                imagePreview.src = '#';
                previewPlaceholder.style.display = 'flex';
                previewContainer.classList.remove('has-image');
            }
        }

        // Giriş alanında her değişiklik olduğunda (yazma, yapıştırma) ön izlemeyi güncelle
        imageUrlInput.addEventListener('input', updateImagePreview);

        // Resim yüklenirken hata oluşursa (geçersiz URL), placeholder'a geri dön
        imagePreview.onerror = function() {
             imagePreview.style.display = 'none';
             imagePreview.src = '#';
             previewPlaceholder.style.display = 'flex';
             previewPlaceholder.innerHTML = '<i class="fa fa-exclamation-triangle fa-3x mb-2 text-warning"></i><span>Resim Yüklenemedi<br/>Geçersiz URL</span>';
             previewContainer.classList.remove('has-image');
        };

        // Sayfa yüklendiğinde (eğer input dolu gelirse - örn. güncelleme) ön izlemeyi çalıştır
        updateImagePreview();
    </script>
}