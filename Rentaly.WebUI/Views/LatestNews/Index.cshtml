@model List<Rentaly.EntityLayer.Entities.LatestNew>

@{
    ViewData["Title"] = "Haber Yönetimi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0 text-uppercase" style="letter-spacing: 1px;">Haber Paneli</h4>
            <span class="text-muted" style="font-size: 0.85rem;">Sistemde kayıtlı @Model.Count haber listeleniyor.</span>
        </div>
        <a href="/LatestNews/CreateNews/" class="btn btn-dark px-4 rounded-3 shadow-sm py-2">
            <i class="fa-solid fa-plus me-2"></i>Yeni Haber Ekle
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
                <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden position-relative">

                    <div class="position-relative">
                        <img src="@item.ImageUrl"
                             class="card-img-top"
                             alt="@item.Title"
                             style="height: 200px; object-fit: cover;"
                             onerror="this.src='/images/default-news.jpg'"> <div class="position-absolute top-0 end-0 m-2">
                            <span class="badge bg-black bg-opacity-75 py-2 px-3 rounded-3 text-white">
                                @item.CreatedDate.Year
                            </span>
                        </div>
                    </div>

                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="card-title fw-bold text-dark mb-0 text-truncate" style="font-size: 1.1rem;">
                                @item.Title
                            </h5>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <span class="badge badge-soft-blue py-2 px-2 flex-fill">
                                <i class="fa-solid fa-calendar-day me-1"></i> @item.CreatedDate.ToString("dd.MM.yyyy")
                            </span>
                            <span class="badge badge-soft-gray py-2 px-2 flex-fill">
                                <i class="fa-solid fa-hashtag me-1"></i> ID: @item.LatestNewId
                            </span>
                        </div>

                        <p class="card-text text-muted small mb-4" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 40px;">
                            @item.Description
                        </p>

                        <hr class="my-3 opacity-5">

                        <div class="row g-2">
                            <div class="col-4">
                                <a href="#" class="btn btn-action-detail w-100 py-2 rounded-3" title="Detay">
                                    <i class="fa-solid fa-circle-info"></i>
                                </a>
                            </div>
                            <div class="col-4">
                                <a href="/LatestNews/UpdateNews/@item.LatestNewId" class="btn btn-action-edit w-100 py-2 rounded-3" title="Düzenle">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                            </div>
                            <div class="col-4">
                                <a href="/LatestNews/DeleteNews/@item.LatestNewId" class="btn btn-action-delete w-100 py-2 rounded-3" title="Sil">
                                    <i class="fa-solid fa-trash-can"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Kart Genel */
    .card {
        transition: transform 0.2s;
        border: 1px solid #f0f0f0;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
        }

    /* Rozet Renkleri (Soft Stil) */
    .badge-soft-blue {
        background-color: #eef2ff;
        color: #4f46e5;
        border: none;
        font-weight: 500;
    }

    .badge-soft-gray {
        background-color: #f8f9fa;
        color: #6c757d;
        border: 1px solid #eee;
        font-weight: 500;
    }

    /* Buton Renkleri (Paylaştığın Görsele Göre) */
    .btn-action-detail {
        background-color: #e8edff;
        color: #4e73df;
        border: none;
    }

        .btn-action-detail:hover {
            background-color: #4e73df;
            color: white;
        }

    .btn-action-edit {
        background-color: #fff4e5;
        color: #ff9800;
        border: none;
    }

        .btn-action-edit:hover {
            background-color: #ff9800;
            color: white;
        }

    .btn-action-delete {
        background-color: #ffebee;
        color: #ef5350;
        border: none;
    }

        .btn-action-delete:hover {
            background-color: #ef5350;
            color: white;
        }

    /* Text Sınırlama */
    .text-truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>