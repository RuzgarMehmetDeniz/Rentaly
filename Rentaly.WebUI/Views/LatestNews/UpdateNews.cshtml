@model LatestNew

@{
    ViewData["Title"] = "Haber Güncelle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom py-3">
                    <div class="d-flex align-items-center">
                        <div class="icon-shape bg-warning bg-opacity-10 text-warning rounded-3 me-3 p-2">
                            <i class="fa-solid fa-pen-to-square fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">Haberi Düzenle</h5>
                            <small class="text-muted">ID: #@Model.LatestNewId numaralı içeriği güncelliyorsunuz.</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="UpdateNews" method="post">
                        @Html.HiddenFor(x => x.LatestNewId)
                        @Html.HiddenFor(x => x.CreatedDate)

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-semibold text-dark">Haber Başlığı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-heading text-muted"></i></span>
                                    <input type="text" asp-for="Title" class="form-control border-start-0 bg-light" placeholder="Başlık giriniz..." required>
                                </div>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold text-dark">Yazar</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-user-pen text-muted"></i></span>
                                    <input type="text" asp-for="Author" class="form-control border-start-0 bg-light" placeholder="Yazar adını güncelleyin..." required>
                                </div>
                            </div>

                            <div class="col-md-8">
                                <label class="form-label fw-semibold text-dark">Görsel URL</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-image text-muted"></i></span>
                                    <input type="text" asp-for="ImageUrl" id="imageUrlInput" class="form-control border-start-0 bg-light" placeholder="https://..." required>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold text-dark">Mevcut Görsel</label>
                                <div class="rounded-3 border overflow-hidden shadow-sm" style="height: 100px; background: #f8f9fa;">
                                    <img src="@Model.ImageUrl" id="imgPreview" class="w-100 h-100" style="object-fit: cover;" onerror="this.src='/images/no-image.png'">
                                </div>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold text-dark">Haber Açıklaması</label>
                                <textarea asp-for="Description" class="form-control bg-light" rows="6" placeholder="Haber detaylarını buraya yazın..." required></textarea>
                            </div>

                            <div class="col-12 mt-4">
                                <hr class="opacity-5 mb-4">
                                <div class="d-flex gap-2 justify-content-end">
                                    <a href="/LatestNews/Index" class="btn btn-light px-4 rounded-3 border">
                                        Vazgeç
                                    </a>
                                    <button type="submit" class="btn btn-warning px-5 rounded-3 text-white fw-bold shadow-sm">
                                        Değişiklikleri Kaydet
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        background-color: #fff !important;
        border-color: #ffc107;
        box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.1);
    }

    .input-group-text {
        border-color: #dee2e6;
    }

    .card {
        border: 1px solid #f0f0f0;
    }
</style>

@section Scripts {
    <script>
        document.getElementById('imageUrlInput').addEventListener('input', function() {
            document.getElementById('imgPreview').src = this.value;
        });
    </script>
}