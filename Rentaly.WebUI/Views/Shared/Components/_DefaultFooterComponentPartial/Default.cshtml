@model List<Contact>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
    /* 1. ANA FOOTER (ÜST KISIM) */
    footer {
        padding: 60px 0 0 0 !important;
        background-color: #111111 !important;
        color: #eeeeee !important;
    }

        footer h5 {
            color: #ffffff !important;
            font-weight: 700;
            margin-bottom: 25px;
        }

        /* Widget Liste Düzenleme */
        footer ul {
            list-style: none;
            padding: 0;
        }

            footer ul li {
                margin-bottom: 10px;
            }

                footer ul li a {
                    color: rgba(255,255,255,0.6) !important;
                    text-decoration: none;
                    transition: 0.3s;
                }

                    footer ul li a:hover {
                        color: #26d120 !important; /* Senin parlak yeşilin */
                    }

    /* İletişim Bilgileri */
    address.s1 span {
        display: block;
        margin-bottom: 15px;
        color: rgba(255,255,255,0.6);
    }

    address.s1 i {
        margin-right: 12px;
        color: #26d120 !important; /* İkonlar yeşil */
    }

    /* 2. SUBFOOTER (İSTEDİĞİN İNCE ALAN) */
    .subfooter {
        padding: 15px 0 !important;
        border-top: 1px solid rgba(255, 255, 255, 0.05) !important;
        background-color: #111111 !important;
        margin-top: 50px;
    }

    .footer-flex-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .footer-copyright {
        font-size: 13px;
        color: #ffffff;
        opacity: 0.8;
    }

        .footer-copyright a {
            color: #ffffff;
            text-decoration: none;
        }

    /* Menü Linkleri (Terms & Conditions) */
    .footer-simple-menu {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 30px;
    }

        .footer-simple-menu li a {
            color: #ffffff !important;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
        }

    /* Yukarı Çık Butonu */
    .scroll-to-top-btn {
        background-color: #26d120 !important;
        color: white !important;
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 5px;
        text-decoration: none;
    }
</style>

<footer class="text-light">
    <div class="container">
        <div class="row g-custom-x">
            <div class="col-lg-3">
                <div class="widget">
                    <h5>Rentaly Hakkında</h5>
                    <p>Kalite ve uygun fiyatın buluştuğu yer. Aşırı maliyetlerin yükü olmadan, sorunsuz ve keyifli bir yolculuğun önemini anlıyoruz.</p>
                </div>
            </div>
            @foreach (var item in Model)
            {
                <div class="col-lg-3">
                    <div class="widget">
                    <h5>İletişim Bilgileri</h5>
                    <address class="s1">
                        <span><i class="fa fa-map-marker"></i>@item.Address</span>
                        <span><i class="fa fa-phone"></i>@item.Phone</span>
                        <span><i class="fa fa-envelope-o"></i><a href="@item.Email" style="color:rgba(255,255,255,0.6);">@item.Email</a></span>
                    </address>
                </div>
            </div>
            }
            <div class="col-lg-3">
                <div class="widget">
                    <h5>Hızlı Linkler</h5>
                    <ul>
                        <li><a href="/Default/Index/">Ana Sayfa</a></li>
                        <li><a href="/NewsLatter/Index/">Haberler</a></li>
                        <li><a href="/CarList/Index/">Arabalar</a></li>
                        <li><a href="/Booking/Index/">Rezervasyon</a></li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="widget">
                    <h5>Sosyal Medyalarımız</h5>
                    <div class="social-icons" style="display: flex; gap: 15px;">
                        <a href="https://www.instagram.com/ruzgardeni_z/?hl=tr" target="_blank">
                            <i class="fa-brands fa-instagram fa-lg"></i>
                        </a>

                        <a href="https://www.linkedin.com/in/r%C3%BCzgar-deniz-25368437a/" target="_blank">
                            <i class="fa-brands fa-linkedin fa-lg"></i>
                        </a>

                        <a href="https://x.com/" target="_blank">
                            <i class="fa-brands fa-x-twitter fa-lg"></i>
                        </a>

                        <a href="https://www.youtube.com/" target="_blank">
                            <i class="fa-brands fa-youtube fa-lg"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="subfooter">
        <div class="container">
            <div class="footer-flex-container">

                <div class="footer-copyright">
                    Telif hakkı 2025 Rentaly by Designesia'ya aittir.
                </div>

                <div class="d-flex align-items-center" style="gap: 40px;">
                    <ul class="footer-simple-menu">
                        <li><a href="#">Şartlar ve Koşullar</a></li>
                        <li><a href="#">Gizlilik Politikası</a></li>
                    </ul>

                    <a href="#" class="scroll-to-top-btn">
                        <i class="fa fa-chevron-up"></i>
                    </a>
                </div>

            </div>
        </div>
    </div>
</footer>