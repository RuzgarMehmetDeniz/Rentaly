@model List<ResultCustomerDto>

@{
    ViewData["Title"] = "CustomerList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    .mini-stat {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px 20px;
        box-shadow: var(--shadow-sm);
        display: flex;
        align-items: center;
        gap: 14px;
        transition: var(--transition);
    }

        .mini-stat:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }

    .mini-stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .mini-stat-val {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 24px;
        font-weight: 800;
        color: var(--text-main);
        line-height: 1;
    }

    .mini-stat-label {
        font-size: 12.5px;
        color: var(--text-muted);
        margin-top: 3px;
    }

    .customer-toolbar {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        box-shadow: var(--shadow-sm);
        margin-bottom: 20px;
    }

    .customer-search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
    }

        .customer-search-wrap i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 14px;
            pointer-events: none;
        }

        .customer-search-wrap input {
            width: 100%;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 9px 12px 9px 36px;
            font-size: 13.5px;
            font-family: 'DM Sans', sans-serif;
            color: var(--text-main);
            background: var(--body-bg);
            outline: none;
            transition: var(--transition);
        }

            .customer-search-wrap input:focus {
                border-color: var(--primary);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(26,86,219,0.1);
            }

    .customers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
        gap: 18px;
        margin-bottom: 20px;
    }

    .customer-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        overflow: visible;
        transition: var(--transition);
        display: flex;
        flex-direction: column;
        position: relative;
    }

        .customer-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-3px);
            border-color: #7c3aed;
        }

    .customer-card-accent {
        height: 5px;
        background: linear-gradient(90deg,#7c3aed 0%,#a78bfa 100%);
        flex-shrink: 0;
    }

    .customer-card-header {
        padding: 18px 18px 14px;
        display: flex;
        align-items: flex-start;
        gap: 14px;
        border-bottom: 1px solid var(--border);
        position: relative;
    }

    .customer-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg,#7c3aed 0%,#a78bfa 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Plus Jakarta Sans',sans-serif;
        font-size: 17px;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
        letter-spacing: -.5px;
    }

    .customer-card-title-block {
        flex: 1;
        min-width: 0;
    }

    .customer-card-name {
        font-family: 'Plus Jakarta Sans',sans-serif;
        font-size: 15px;
        font-weight: 800;
        color: var(--text-main);
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .customer-card-id {
        display: inline-block;
        margin-top: 4px;
        background: #f5f3ff;
        border: 1px solid #ddd6fe;
        color: #7c3aed;
        font-family: 'Plus Jakarta Sans',sans-serif;
        font-size: 11px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 5px;
        letter-spacing: .5px;
    }

    /* ── Dropdown Menü ── */
    .card-menu-btn {
        position: absolute;
        top: 14px;
        right: 14px;
        width: 30px;
        height: 30px;
        border-radius: 6px;
        background: #f5f3ff;
        border: 1px solid #ddd6fe;
        color: #7c3aed;
        font-size: 14px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
        z-index: 10;
    }

        .card-menu-btn:hover {
            background: #7c3aed;
            color: #fff;
        }

    .card-dropdown {
        position: absolute;
        top: 48px;
        right: 14px;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: 0 8px 24px rgba(0,0,0,.12);
        min-width: 170px;
        z-index: 9999;
        display: none;
        overflow: hidden;
    }

        .card-dropdown.open {
            display: block;
        }

    .card-dropdown-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        font-size: 13.5px;
        font-weight: 600;
        font-family: 'DM Sans',sans-serif;
        cursor: pointer;
        transition: background .15s;
        text-decoration: none;
        color: var(--text-main);
        border: none;
        background: none;
        width: 100%;
    }

        .card-dropdown-item:hover {
            background: #f5f3ff;
            color: #7c3aed;
        }

        .card-dropdown-item.danger:hover {
            background: #fee2e2;
            color: var(--danger);
        }

        .card-dropdown-item i {
            width: 16px;
            text-align: center;
        }

    .card-dropdown-divider {
        height: 1px;
        background: var(--border);
        margin: 4px 0;
    }

    .customer-card-body {
        padding: 16px 18px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .customer-info-row {
        display: flex;
        align-items: flex-start;
        gap: 10px;
    }

    .customer-info-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        flex-shrink: 0;
        margin-top: 1px;
    }

        .customer-info-icon.email {
            background: #eff6ff;
            color: #3b82f6;
        }

        .customer-info-icon.phone {
            background: #f0fdf4;
            color: #16a34a;
        }

        .customer-info-icon.license {
            background: #fdf4ff;
            color: #a21caf;
        }

        .customer-info-icon.id-num {
            background: #fff7ed;
            color: #ea580c;
        }

    .customer-info-text {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .customer-info-label {
        font-size: 11px;
        color: var(--text-muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        line-height: 1;
        margin-bottom: 2px;
    }

    .customer-info-value {
        font-size: 13.5px;
        color: var(--text-main);
        font-weight: 500;
        line-height: 1.4;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .license-date-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #16a34a;
        font-size: 11.5px;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 6px;
    }

    /* Detay Modal */
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .detail-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: var(--text-muted);
    }

    .detail-value {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-main);
        background: var(--body-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 8px 12px;
    }

    .empty-state {
        padding: 64px 20px;
        text-align: center;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
    }

    .empty-icon {
        width: 72px;
        height: 72px;
        background: #f5f3ff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: #7c3aed;
        margin: 0 auto 18px;
    }

    .paging-wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 4px;
        flex-wrap: wrap;
        gap: 8px;
    }

    .paging-info {
        font-size: 13px;
        color: var(--text-muted);
    }

    .paging-btns {
        display: flex;
        gap: 4px;
    }

    .page-btn {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        background: #fff;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        color: var(--text-main);
        font-family: 'Plus Jakarta Sans',sans-serif;
    }

        .page-btn:hover {
            background: #f5f3ff;
            border-color: #7c3aed;
            color: #7c3aed;
        }

        .page-btn.active {
            background: #7c3aed;
            border-color: #7c3aed;
            color: #fff;
        }

        .page-btn:disabled {
            opacity: .4;
            cursor: not-allowed;
        }

    .view-toggle {
        display: flex;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        overflow: hidden;
    }

    .view-btn {
        width: 36px;
        height: 36px;
        border: none;
        background: #fff;
        color: var(--text-muted);
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

        .view-btn.active {
            background: #7c3aed;
            color: #fff;
        }

        .view-btn:hover:not(.active) {
            background: #f5f3ff;
            color: #7c3aed;
        }

    .customers-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 20px;
    }

    .customer-list-item {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 14px 18px;
        transition: var(--transition);
        position: relative;
        overflow: visible;
    }

        .customer-list-item::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            background: linear-gradient(180deg,#7c3aed 0%,#a78bfa 100%);
            border-radius: 4px 0 0 4px;
        }

        .customer-list-item:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-1px);
            border-color: #7c3aed;
        }

    .customer-list-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg,#7c3aed 0%,#a78bfa 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Plus Jakarta Sans',sans-serif;
        font-size: 15px;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
    }

    .customer-list-info {
        flex: 1;
        min-width: 0;
    }

    .customer-list-name {
        font-family: 'Plus Jakarta Sans',sans-serif;
        font-size: 14.5px;
        font-weight: 800;
        color: var(--text-main);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .customer-list-id-badge {
        background: #f5f3ff;
        border: 1px solid #ddd6fe;
        color: #7c3aed;
        font-size: 10.5px;
        font-weight: 700;
        padding: 2px 7px;
        border-radius: 4px;
        letter-spacing: .5px;
    }

    .customer-list-sub {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-top: 5px;
        flex-wrap: wrap;
    }

    .customer-list-meta {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12.5px;
        color: var(--text-muted);
    }

        .customer-list-meta i {
            font-size: 11px;
            color: #7c3aed;
        }

    @@media (max-width: 575px) {
        .customers-grid {
            grid-template-columns: 1fr;
        }

        .detail-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Müşteri Listesi</h1>
        <p class="page-subtitle">Tüm müşterileri görüntüleyin ve yönetin.</p>
    </div>
    <a href="/Customer/CreateCustomer" class="btn-primary-custom">
        <i class="fa-solid fa-plus"></i> Yeni Müşteri
    </a>
</div>

<!-- Mini İstatistikler -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="mini-stat">
            <div class="mini-stat-icon" style="background:#f5f3ff;color:#7c3aed;"><i class="fa-solid fa-users"></i></div>
            <div>
                <div class="mini-stat-val" style="color:#7c3aed;">@Model.Count()</div>
                <div class="mini-stat-label">Toplam Müşteri</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="mini-stat">
            <div class="mini-stat-icon" style="background:#d1fae5;color:#059669;"><i class="fa-solid fa-id-card"></i></div>
            <div>
                <div class="mini-stat-val" style="color:#059669;">@Model.Count(c => !string.IsNullOrEmpty(c.DrivingLicenseNumber))</div>
                <div class="mini-stat-label">Ehliyeti Olan</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="mini-stat">
            <div class="mini-stat-icon" style="background:#fff7ed;color:#ea580c;"><i class="fa-solid fa-envelope"></i></div>
            <div>
                <div class="mini-stat-val" style="color:#ea580c;">@Model.Count(c => !string.IsNullOrEmpty(c.Email))</div>
                <div class="mini-stat-label">E-postası Kayıtlı</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="mini-stat">
            <div class="mini-stat-icon" style="background:#eff6ff;color:#3b82f6;"><i class="fa-solid fa-phone"></i></div>
            <div>
                <div class="mini-stat-val" style="color:#3b82f6;">@Model.Count(c => !string.IsNullOrEmpty(c.Phone))</div>
                <div class="mini-stat-label">Telefonu Kayıtlı</div>
            </div>
        </div>
    </div>
</div>

<!-- Toolbar -->
<div class="customer-toolbar">
    <div class="customer-search-wrap">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="customerSearch" placeholder="Ad, soyad, e-posta, telefon ara…" oninput="filterCustomers()" />
    </div>
    <select class="filter-select" id="sortSelect" onchange="filterCustomers()" style="min-width:200px;">
        <option value="id-asc">ID — Artan</option>
        <option value="id-desc">ID — Azalan</option>
        <option value="name-asc">Ad — A'dan Z'ye</option>
        <option value="name-desc">Ad — Z'den A'ya</option>
        <option value="surname-asc">Soyad — A'dan Z'ye</option>
        <option value="surname-desc">Soyad — Z'den A'ya</option>
    </select>
    <div class="view-toggle">
        <button class="view-btn active" id="btnGridView" onclick="setView('grid')" title="Kart Görünümü">
            <i class="fa-solid fa-grip"></i>
        </button>
        <button class="view-btn" id="btnListView" onclick="setView('list')" title="Liste Görünümü">
            <i class="fa-solid fa-list"></i>
        </button>
    </div>
    <button class="btn-action btn-detail" onclick="resetCustomerFilters()" style="flex:none;padding:9px 14px;font-size:13px;white-space:nowrap;">
        <i class="fa-solid fa-rotate-left"></i> Sıfırla
    </button>
</div>

<!-- Kart Grid Görünümü -->
<div class="customers-grid" id="customersGrid">
    @foreach (var customer in Model)
    {
        var initials = $"{(string.IsNullOrEmpty(customer.Name) ? "?" : customer.Name[0].ToString())}{(string.IsNullOrEmpty(customer.Surname) ? "" : customer.Surname[0].ToString())}".ToUpper();
        var fullName = $"{customer.Name} {customer.Surname}".Trim();

        <div class="customer-card"
             data-id="@customer.CustomerId"
             data-name="@customer.Name?.ToLower()"
             data-surname="@customer.Surname?.ToLower()"
             data-email="@customer.Email?.ToLower()"
             data-phone="@customer.Phone?.ToLower()">

            <div class="customer-card-accent"></div>

            <div class="customer-card-header">
                <div class="customer-avatar">@initials</div>
                <div class="customer-card-title-block">
                    <div class="customer-card-name">@fullName</div>
                    <span class="customer-card-id">#@customer.CustomerId</span>
                </div>

                <!-- Üç Nokta Menü -->
                <button class="card-menu-btn" onclick="toggleMenu(event, 'menu-@customer.CustomerId')">
                    <i class="fa-solid fa-ellipsis-vertical"></i>
                </button>
                <div class="card-dropdown" id="menu-@customer.CustomerId">
                    <button class="card-dropdown-item"
                            onclick="openDetailModal(
                                    '@customer.CustomerId',
                                    '@fullName',
                                    '@customer.Email',
                                    '@customer.Phone',
                                    '@customer.IdentityNumber',
                                    '@customer.DrivingLicenseNumber',
                                    '@customer.DrivingLicenseDate.ToString("dd.MM.yyyy")')">
                        <i class="fa-solid fa-eye"></i> Detay
                    </button>
                    <a class="card-dropdown-item" href="/Customer/UpdateCustomer/@customer.CustomerId">
                        <i class="fa-solid fa-pen-to-square"></i> Düzenle
                    </a>
                    <div class="card-dropdown-divider"></div>
                    <button class="card-dropdown-item danger"
                            onclick="openDeleteModal(@customer.CustomerId, '@fullName')">
                        <i class="fa-solid fa-trash-can"></i> Sil
                    </button>
                </div>
            </div>

            <div class="customer-card-body">
                <div class="customer-info-row">
                    <div class="customer-info-icon email"><i class="fa-solid fa-envelope"></i></div>
                    <div class="customer-info-text">
                        <span class="customer-info-label">E-posta</span>
                        <span class="customer-info-value">@(string.IsNullOrEmpty(customer.Email) ? "—" : customer.Email)</span>
                    </div>
                </div>
                <div class="customer-info-row">
                    <div class="customer-info-icon phone"><i class="fa-solid fa-phone"></i></div>
                    <div class="customer-info-text">
                        <span class="customer-info-label">Telefon</span>
                        <span class="customer-info-value">@(string.IsNullOrEmpty(customer.Phone) ? "—" : customer.Phone)</span>
                    </div>
                </div>
                <div class="customer-info-row">
                    <div class="customer-info-icon id-num"><i class="fa-solid fa-fingerprint"></i></div>
                    <div class="customer-info-text">
                        <span class="customer-info-label">TC Kimlik No</span>
                        <span class="customer-info-value">@(string.IsNullOrEmpty(customer.IdentityNumber) ? "—" : customer.IdentityNumber)</span>
                    </div>
                </div>
                <div class="customer-info-row">
                    <div class="customer-info-icon license"><i class="fa-solid fa-id-card"></i></div>
                    <div class="customer-info-text">
                        <span class="customer-info-label">Ehliyet No / Tarih</span>
                        <span class="customer-info-value">
                            @(string.IsNullOrEmpty(customer.DrivingLicenseNumber) ? "—" : customer.DrivingLicenseNumber)
                            @if (customer.DrivingLicenseDate != default)
                            {
                                <span class="license-date-badge" style="margin-left:4px;">
                                    <i class="fa-solid fa-calendar-check" style="font-size:10px;"></i>
                                    @customer.DrivingLicenseDate.ToString("dd.MM.yyyy")
                                </span>
                            }
                        </span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Liste Görünümü -->
<div class="customers-list" id="customersList" style="display:none;">
    @foreach (var customer in Model)
    {
        var initials = $"{(string.IsNullOrEmpty(customer.Name) ? "?" : customer.Name[0].ToString())}{(string.IsNullOrEmpty(customer.Surname) ? "" : customer.Surname[0].ToString())}".ToUpper();
        var fullName = $"{customer.Name} {customer.Surname}".Trim();

        <div class="customer-list-item"
             data-id="@customer.CustomerId"
             data-name="@customer.Name?.ToLower()"
             data-surname="@customer.Surname?.ToLower()"
             data-email="@customer.Email?.ToLower()"
             data-phone="@customer.Phone?.ToLower()">

            <div class="customer-list-avatar">@initials</div>
            <div class="customer-list-info">
                <div class="customer-list-name">
                    @fullName
                    <span class="customer-list-id-badge">#@customer.CustomerId</span>
                </div>
                <div class="customer-list-sub">
                    <span class="customer-list-meta"><i class="fa-solid fa-envelope"></i> @(string.IsNullOrEmpty(customer.Email) ? "E-posta yok" : customer.Email)</span>
                    <span style="color:var(--border);">·</span>
                    <span class="customer-list-meta"><i class="fa-solid fa-phone"></i> @(string.IsNullOrEmpty(customer.Phone) ? "Telefon yok" : customer.Phone)</span>
                </div>
            </div>

            <!-- Liste Üç Nokta Menü -->
            <div style="position:relative;flex-shrink:0;">
                <button class="card-menu-btn" onclick="toggleMenu(event, 'listmenu-@customer.CustomerId')">
                    <i class="fa-solid fa-ellipsis-vertical"></i>
                </button>
                <div class="card-dropdown" id="listmenu-@customer.CustomerId">
                    <button class="card-dropdown-item"
                            onclick="openDetailModal(
                                    '@customer.CustomerId',
                                    '@fullName',
                                    '@customer.Email',
                                    '@customer.Phone',
                                    '@customer.IdentityNumber',
                                    '@customer.DrivingLicenseNumber',
                                    '@customer.DrivingLicenseDate.ToString("dd.MM.yyyy")')">
                        <i class="fa-solid fa-eye"></i> Detay
                    </button>
                    <a class="card-dropdown-item" href="/Customer/UpdateCustomer/@customer.CustomerId">
                        <i class="fa-solid fa-pen-to-square"></i> Düzenle
                    </a>
                    <div class="card-dropdown-divider"></div>
                    <button class="card-dropdown-item danger"
                            onclick="openDeleteModal(@customer.CustomerId, '@fullName')">
                        <i class="fa-solid fa-trash-can"></i> Sil
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<!-- Boş Durum -->
<div class="empty-state" id="emptyState" style="display:none;">
    <div class="empty-icon"><i class="fa-solid fa-users"></i></div>
    <h6 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;margin-bottom:6px;">Müşteri Bulunamadı</h6>
    <p style="font-size:13.5px;color:var(--text-muted);margin-bottom:14px;">Arama kriterinizle eşleşen müşteri yok.</p>
    <button class="btn-primary-custom" onclick="resetCustomerFilters()">
        <i class="fa-solid fa-rotate-left"></i> Filtreyi Temizle
    </button>
</div>

<!-- Pagination -->
<div class="paging-wrap" id="pagingWrap" style="display:none;">
    <div class="paging-info" id="pagingInfo">—</div>
    <div class="paging-btns" id="pagingBtns"></div>
</div>

<!-- ═══ DETAY MODAL ═══ -->
<div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:480px;">
        <div class="modal-content">
            <div class="modal-header">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:34px;height:34px;background:#f5f3ff;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#7c3aed;font-size:15px;">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    <h5 class="modal-title">Müşteri Detayı</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Avatar + İsim -->
                <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border);">
                    <div id="detailAvatar" style="width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#7c3aed,#a78bfa);display:flex;align-items:center;justify-content:center;font-family:'Plus Jakarta Sans',sans-serif;font-size:20px;font-weight:800;color:#fff;flex-shrink:0;"></div>
                    <div>
                        <div id="detailName" style="font-family:'Plus Jakarta Sans',sans-serif;font-size:17px;font-weight:800;color:var(--text-main);"></div>
                        <div id="detailIdBadge" style="display:inline-block;margin-top:4px;background:#f5f3ff;border:1px solid #ddd6fe;color:#7c3aed;font-size:11px;font-weight:700;padding:2px 8px;border-radius:5px;"></div>
                    </div>
                </div>
                <!-- Detay Grid -->
                <div class="detail-grid">
                    <div class="detail-item">
                        <span class="detail-label"><i class="fa-solid fa-envelope" style="color:#3b82f6;margin-right:5px;"></i>E-posta</span>
                        <span class="detail-value" id="detailEmail">—</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label"><i class="fa-solid fa-phone" style="color:#16a34a;margin-right:5px;"></i>Telefon</span>
                        <span class="detail-value" id="detailPhone">—</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label"><i class="fa-solid fa-fingerprint" style="color:#ea580c;margin-right:5px;"></i>TC Kimlik No</span>
                        <span class="detail-value" id="detailIdentity">—</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label"><i class="fa-solid fa-id-card" style="color:#a21caf;margin-right:5px;"></i>Ehliyet No</span>
                        <span class="detail-value" id="detailLicense">—</span>
                    </div>
                    <div class="detail-item" style="grid-column:1/-1;">
                        <span class="detail-label"><i class="fa-solid fa-calendar-check" style="color:#16a34a;margin-right:5px;"></i>Ehliyet Tarihi</span>
                        <span class="detail-value" id="detailLicenseDate">—</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel-form" data-bs-dismiss="modal"
                        style="display:inline-flex;align-items:center;gap:6px;">
                    <i class="fa-solid fa-xmark"></i> Kapat
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ═══ SİL ONAY MODAL ═══ -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content">
            <div class="modal-header">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:34px;height:34px;background:#fee2e2;border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--danger);font-size:15px;">
                        <i class="fa-solid fa-trash-can"></i>
                    </div>
                    <h5 class="modal-title">Müşteri Sil</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div style="display:flex;gap:14px;align-items:flex-start;">
                    <div style="width:46px;height:46px;background:#fee2e2;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--danger);font-size:20px;flex-shrink:0;">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                    <div>
                        <p style="margin:0;font-size:14.5px;color:var(--text-main);line-height:1.5;">
                            <strong id="deleteCustomerName"></strong> silmek istediğinizden emin misiniz?
                        </p>
                        <p style="margin:6px 0 0;font-size:13px;color:var(--text-muted);">
                            Bu işlem geri alınamaz.
                        </p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel-form" data-bs-dismiss="modal"
                        style="display:inline-flex;align-items:center;gap:6px;">
                    <i class="fa-solid fa-xmark"></i> Vazgeç
                </button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteCustomerId" name="id" />
                    <button type="submit"
                            style="display:inline-flex;align-items:center;gap:7px;background:var(--danger);color:#fff;border:none;border-radius:var(--radius-sm);padding:9px 22px;font-size:13.5px;font-weight:700;font-family:'DM Sans',sans-serif;cursor:pointer;">
                        <i class="fa-solid fa-trash-can"></i> Evet, Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>

<script>
    let currentView = 'grid';
    let currentPage = 1;
    const PAGE_SIZE = 12;

    // Dropdown aç/kapat
    function toggleMenu(e, id) {
        e.stopPropagation();
        document.querySelectorAll('.card-dropdown.open').forEach(d => {
            if (d.id !== id) d.classList.remove('open');
        });
        document.getElementById(id).classList.toggle('open');
    }

    // Dışarı tıklayınca kapat
    document.addEventListener('click', () => {
        document.querySelectorAll('.card-dropdown.open').forEach(d => d.classList.remove('open'));
    });

    // Detay Modal
    function openDetailModal(id, name, email, phone, identity, license, licenseDate) {
        document.querySelectorAll('.card-dropdown.open').forEach(d => d.classList.remove('open'));
        const initials = name.split(' ').map(w => w[0] || '').join('').toUpperCase().slice(0, 2);
        document.getElementById('detailAvatar').textContent    = initials;
        document.getElementById('detailName').textContent      = name;
        document.getElementById('detailIdBadge').textContent   = '#' + id;
        document.getElementById('detailEmail').textContent     = email    || '—';
        document.getElementById('detailPhone').textContent     = phone    || '—';
        document.getElementById('detailIdentity').textContent  = identity || '—';
        document.getElementById('detailLicense').textContent   = license  || '—';
        document.getElementById('detailLicenseDate').textContent = licenseDate || '—';
        new bootstrap.Modal(document.getElementById('detailModal')).show();
    }

    // Sil Modal
    function openDeleteModal(id, name) {
        document.querySelectorAll('.card-dropdown.open').forEach(d => d.classList.remove('open'));
        document.getElementById('deleteCustomerName').textContent = `"${name}"`;
        document.getElementById('deleteCustomerId').value         = id;
        document.getElementById('deleteForm').action             = `/Customer/DeleteCustomer/${id}`;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }

    function setView(v) {
        currentView = v;
        document.getElementById('customersGrid').style.display = v === 'grid' ? 'grid' : 'none';
        document.getElementById('customersList').style.display = v === 'list' ? 'flex' : 'none';
        document.getElementById('btnGridView').classList.toggle('active', v === 'grid');
        document.getElementById('btnListView').classList.toggle('active', v === 'list');
        currentPage = 1;
        applyFilters();
    }

    function filterCustomers() { currentPage = 1; applyFilters(); }

    function applyFilters() {
        const q    = document.getElementById('customerSearch').value.toLowerCase().trim();
        const sort = document.getElementById('sortSelect').value;
        const gridCards = [...document.querySelectorAll('#customersGrid .customer-card')];
        const listItems = [...document.querySelectorAll('#customersList .customer-list-item')];

        const filterItem = (item) => {
            if (!q) return true;
            return ['name','surname','email','phone','id'].some(k => (item.dataset[k] || '').includes(q));
        };

        gridCards.forEach(c => c.setAttribute('data-show', filterItem(c) ? '1' : '0'));
        listItems.forEach(c => c.setAttribute('data-show', filterItem(c) ? '1' : '0'));

        const [sortField, sortDir] = sort.split('-');
        const sortItems = (list) => {
            list.sort((a, b) => {
                let va, vb;
                if      (sortField === 'id')      { va = parseInt(a.dataset.id); vb = parseInt(b.dataset.id); }
                else if (sortField === 'name')    { va = a.dataset.name    || ''; vb = b.dataset.name    || ''; }
                else if (sortField === 'surname') { va = a.dataset.surname || ''; vb = b.dataset.surname || ''; }
                if (typeof va === 'string') return sortDir === 'asc' ? va.localeCompare(vb,'tr') : vb.localeCompare(va,'tr');
                return sortDir === 'asc' ? va - vb : vb - va;
            });
        };

        sortItems(gridCards); sortItems(listItems);
        const gp = document.getElementById('customersGrid');
        const lp = document.getElementById('customersList');
        gridCards.forEach(c => gp.appendChild(c));
        listItems.forEach(c => lp.appendChild(c));
        buildPaging();
    }

    function resetCustomerFilters() {
        document.getElementById('customerSearch').value = '';
        document.getElementById('sortSelect').value = 'id-asc';
        currentPage = 1;
        applyFilters();
        showToast('Filtreler sıfırlandı.', 'info');
    }

    function buildPaging() {
        const activeItems = currentView === 'grid'
            ? [...document.querySelectorAll('#customersGrid .customer-card')]
            : [...document.querySelectorAll('#customersList .customer-list-item')];

        const filtered = activeItems.filter(c => c.getAttribute('data-show') === '1');
        const total = filtered.length;
        const pages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        if (currentPage > pages) currentPage = pages;

        activeItems.forEach(c => c.style.display = 'none');
        filtered.forEach((c, i) => {
            if (i >= (currentPage-1)*PAGE_SIZE && i < currentPage*PAGE_SIZE) c.style.display = '';
        });

        const inactiveItems = currentView === 'grid'
            ? [...document.querySelectorAll('#customersList .customer-list-item')]
            : [...document.querySelectorAll('#customersGrid .customer-card')];
        inactiveItems.forEach(c => c.style.display = 'none');

        document.getElementById('emptyState').style.display = total === 0 ? 'block' : 'none';

        const from = total === 0 ? 0 : (currentPage-1)*PAGE_SIZE+1;
        const to   = Math.min(currentPage*PAGE_SIZE, total);
        document.getElementById('pagingInfo').textContent = total > 0 ? `${from}–${to} / toplam ${total} müşteri` : '0 müşteri';

        const btns = document.getElementById('pagingBtns');
        btns.innerHTML = '';
        const prev = makePageBtn('<i class="fa-solid fa-chevron-left" style="font-size:11px;"></i>', () => goPage(currentPage-1));
        if (currentPage === 1) prev.disabled = true;
        btns.appendChild(prev);
        for (let p = 1; p <= pages; p++) {
            const btn = makePageBtn(p, () => goPage(p));
            if (p === currentPage) btn.classList.add('active');
            btns.appendChild(btn);
        }
        const next = makePageBtn('<i class="fa-solid fa-chevron-right" style="font-size:11px;"></i>', () => goPage(currentPage+1));
        if (currentPage === pages) next.disabled = true;
        btns.appendChild(next);
        document.getElementById('pagingWrap').style.display = total <= PAGE_SIZE && pages === 1 ? 'none' : 'flex';
    }

    function makePageBtn(html, fn) {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'page-btn';
        b.innerHTML = html; b.addEventListener('click', fn);
        return b;
    }

    function goPage(p) {
        const filtered = (currentView === 'grid'
            ? [...document.querySelectorAll('#customersGrid .customer-card')]
            : [...document.querySelectorAll('#customersList .customer-list-item')]
        ).filter(c => c.getAttribute('data-show') === '1');
        const pages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
        currentPage = Math.max(1, Math.min(pages, p));
        buildPaging();
    }

    document.addEventListener('DOMContentLoaded', () => {
        applyFilters();
        @if (TempData["Success"] != null)
        {
            <text>showToast('@TempData["Success"]', 'success');</text>
        }
        @if (TempData["Error"] != null)
        {
            <text>showToast('@TempData["Error"]',   'danger');</text>
        }
    });
</script>