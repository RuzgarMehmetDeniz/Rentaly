@model Award

@{
    ViewData["Title"] = "Yeni Ödül Ekle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid pt-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 py-3">
            <h4 class="mb-0 fw-bold text-dark">✨ Yeni Ödül Tanımla</h4>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <div class="row">

                    <!-- TITLE EKLENDİ -->
                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-semibold">Ödül Başlığı</label>
                        <input type="text" asp-for="Title" class="form-control shadow-none" placeholder="Örn: Ayın Çalışanı" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Ödül İkonu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i id="iconPreview" class="fas fa-award text-primary"></i>
                            </span>
                            <input type="text" asp-for="Icon" id="iconInput" class="form-control border-start-0 shadow-none" placeholder="Örn: fas fa-trophy" required>
                        </div>
                        <small class="text-muted mt-1 d-block">FontAwesome sınıfını yazın (örn: fas fa-star)</small>
                    </div>

                    <div class="col-md-12 mb-4">
                        <label class="form-label fw-semibold">Ödül Açıklaması</label>
                        <textarea asp-for="Desxription" class="form-control shadow-none" rows="3" placeholder="Ödül detaylarını giriniz..." required></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 rounded-pill">Kaydet</button>
                    <a href="/Award/Index/" class="btn btn-outline-secondary px-4 rounded-pill">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // İkon Önizleme Fonksiyonu
    document.getElementById('iconInput').addEventListener('input', function () {
        const iconClass = this.value;
        const preview = document.getElementById('iconPreview');
        preview.className = iconClass + " text-primary";
    });
</script>